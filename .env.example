# ── Brimble Pipeline — environment reference ──────────────────────────────────
# Copy this to .env if you need to override defaults for local dev (outside Docker).
# When running via Docker Compose you do NOT need a .env file — all defaults are
# already set in docker-compose.yml.

# Postgres (internal to Docker; no host port exposed)
DATABASE_URL=postgresql://postgres:postgres@db:5432/brimble

# Redis (internal to Docker; no host port exposed)
REDIS_HOST=redis
REDIS_PORT=6379

# Caddy — admin API used by the NestJS API to register routes
CADDY_ADMIN_URL=http://caddy:2019

# Port Caddy listens on (host-side). Must match docker-compose.yml.
# Deployed apps will be reachable at http://<slug>.localhost:7402
CADDY_PUBLIC_PORT=7402

# Docker socket & BuildKit
DOCKER_SOCKET=/var/run/docker.sock
BUILDKIT_HOST=tcp://buildkit:1234

# Railpack build cache (mounted volume inside the API container)
RAILPACK_CACHE_DIR=/cache

# Encryption — MUST be 32+ characters; used to encrypt env var values at rest
ENCRYPTION_KEY=your-super-secret-key-minimum-32-characters-long

# Webhooks
GITHUB_WEBHOOK_SECRET=
API_BASE_URL=http://localhost:7401

# Frontend → API URL (baked into the React bundle at build time)
# Change to your server's IP/hostname if running on a remote machine.
VITE_API_URL=http://localhost:7401
